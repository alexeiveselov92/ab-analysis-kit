---
// The abkit "Diverge" logomark + optional "abkit" wordmark lockup.
//
// The mark is the canonical asset from docs/design/logo/logomark.svg (Iris tile,
// paper strokes): one assignment node fans into two arms — treatment climbs to the
// accented effect point (dot), control holds the baseline. Geometry (rx = 26/100,
// stroke-width 8) is brand-locked, so the fills are the real brand hex verbatim,
// NOT tokenized (a logo is a fixed asset, mirroring the donor's Logo.astro).
//
// Props:
//   size      — mark edge length in px (default 32; call sites use 28–30).
//   wordmark  — render the "abkit" wordmark beside the mark (default false, so this
//               stays a drop-in for the donor's mark-only <Logo/> lockups).
//   mono      — ink-tile variant for single-colour print / dark chrome
//               (docs/design/logo/logomark-mono.svg).
//   class     — passthrough class on the outer element.
interface Props {
  size?: number;
  wordmark?: boolean;
  mono?: boolean;
  class?: string;
}
const { size = 32, wordmark = false, mono = false, class: className } = Astro.props;
const tile = mono ? '#1B1916' : '#6A45C4';
// When the wordmark is present it carries the accessible name and the mark is
// decorative; standalone, the mark labels itself.
const svgA11y = wordmark
  ? { 'aria-hidden': 'true' as const }
  : { role: 'img' as const, 'aria-label': 'abkit' };
---
{wordmark ? (
  <span class:list={['logo-lockup', className]}>
    <svg
      width={size}
      height={size}
      viewBox="0 0 100 100"
      xmlns="http://www.w3.org/2000/svg"
      {...svgA11y}
    >
      <rect x="3" y="3" width="94" height="94" rx="26" fill={tile}></rect>
      <polyline points="13,50 34,50" fill="none" stroke="#FBF9F3" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"></polyline>
      <polyline points="34,50 86,27" fill="none" stroke="#FBF9F3" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"></polyline>
      <polyline points="34,50 86,61" fill="none" stroke="#FBF9F3" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"></polyline>
      <circle cx="86" cy="27" r="6.5" fill="#FBF9F3"></circle>
    </svg>
    <span class="logo-wordmark">abkit</span>
  </span>
) : (
  <svg
    width={size}
    height={size}
    viewBox="0 0 100 100"
    class={className}
    xmlns="http://www.w3.org/2000/svg"
    {...svgA11y}
  >
    <rect x="3" y="3" width="94" height="94" rx="26" fill={tile}></rect>
    <polyline points="13,50 34,50" fill="none" stroke="#FBF9F3" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"></polyline>
    <polyline points="34,50 86,27" fill="none" stroke="#FBF9F3" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"></polyline>
    <polyline points="34,50 86,61" fill="none" stroke="#FBF9F3" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"></polyline>
    <circle cx="86" cy="27" r="6.5" fill="#FBF9F3"></circle>
  </svg>
)}

<style>
  .logo-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  /* Wordmark: Schibsted Grotesk 700, tightened like the brand lockup.
     Colour is left to inherit so header / footer / dark chrome own it
     (mirrors the donor's .site-title, which sets weight + tracking only). */
  .logo-wordmark {
    font-family: 'Schibsted Grotesk', system-ui, sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: 1.125rem;
    line-height: 1;
    color: inherit;
  }
</style>
